@model IReadOnlyList<Finans.Application.Dtos.Identity.UserListItem>

<div class="page-header">
    <h2><i class="bi bi-people me-2"></i>Kullanıcı Yönetimi</h2>
    <a href="/Admin/CreateUser" class="btn btn-primary btn-sm"><i class="bi bi-person-plus me-1"></i>Yeni Kullanıcı</a>
</div>

@if (Model != null && Model.Count > 0)
{
    <div class="table-container">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead>
                    <tr><th>ID</th><th>Kullanıcı Adı</th><th>Ad Soyad</th><th>Email</th><th>Aktif</th><th>Roller</th><th>İşlem</th></tr>
                </thead>
                <tbody>
                    @foreach (var u in Model)
                    {
                        <tr>
                            <td>@u.Id</td>
                            <td><strong>@u.UserName</strong></td>
                            <td>@u.FirstName @u.LastName</td>
                            <td>@u.Email</td>
                            <td><span class="badge @(u.IsActive ? "bg-success" : "bg-danger")">@(u.IsActive ? "Aktif" : "Pasif")</span></td>
                            <td>
                                @if (u.Roles != null)
                                {
                                    @foreach (var r in u.Roles)
                                    {
                                        <span class="badge bg-info me-1">@r</span>
                                    }
                                }
                            </td>
                            <td>
                                <a href="/Admin/AssignRole?userId=@u.Id" class="btn btn-outline-primary btn-sm" title="Rol Ata">
                                    <i class="bi bi-shield-check"></i>
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}
else
{
    <div class="empty-state"><i class="bi bi-people"></i><p>Kullanıcı bulunamadı.</p></div>
}
