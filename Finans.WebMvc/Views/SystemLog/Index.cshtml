@using Finans.Contracts.Logging
@{
    var auditLogs = ViewBag.AuditLogs as IReadOnlyList<AuditLogDto>;
    var notifications = ViewBag.Notifications as IReadOnlyList<SystemNotificationDto>;
}

<div class="page-header">
    <h2><i class="bi bi-journal-text me-2"></i>Sistem Logları</h2>
    <span class="breadcrumb-nav"><a href="/Dashboard">Dashboard</a> / Sistem Logları</span>
</div>

<div class="row g-3">
    <!-- BİLDİRİMLER -->
    <div class="col-lg-5">
        <div class="card">
            <div class="card-header">
                <h6><i class="bi bi-bell me-2"></i>Bildirimler</h6>
                @if (notifications != null)
                {
                    <span class="badge bg-info">@notifications.Count(n => !n.IsRead) okunmamış</span>
                }
            </div>
            <div class="card-body p-0" style="max-height:500px;overflow-y:auto;">
                @if (notifications != null && notifications.Count > 0)
                {
                    @foreach (var n in notifications)
                    {
                        <div class="p-3 border-bottom @(!n.IsRead ? "bg-light" : "")" style="font-size:.875rem;">
                            <div class="d-flex justify-content-between align-items-start">
                                <div>
                                    <span class="badge @(n.Level == "Error" ? "bg-danger" : n.Level == "Warning" ? "bg-warning" : "bg-info") me-1">@n.Level</span>
                                    <strong>@n.Title</strong>
                                </div>
                                @if (!n.IsRead)
                                {
                                    <form method="post" action="/SystemLog/MarkNotificationAsRead" style="display:inline;">
                                        <input type="hidden" name="id" value="@n.Id" />
                                        <button type="submit" class="btn btn-sm btn-outline-primary" style="font-size:.7rem;">Okundu</button>
                                    </form>
                                }
                            </div>
                            <p class="text-muted mb-1 mt-1">@n.Message</p>
                            <small class="text-muted">@n.CreatedAtUtc.ToString("dd.MM.yyyy HH:mm") &bull; @n.Source</small>
                        </div>
                    }
                }
                else
                {
                    <div class="empty-state"><i class="bi bi-bell-slash"></i><p>Bildirim yok</p></div>
                }
            </div>
        </div>
    </div>

    <!-- AUDIT LOG -->
    <div class="col-lg-7">
        <div class="card">
            <div class="card-header"><h6><i class="bi bi-shield-check me-2"></i>Denetim Logları</h6></div>
            <div class="card-body p-0">
                @if (auditLogs != null && auditLogs.Count > 0)
                {
                    <div class="table-responsive" style="max-height:500px;overflow-y:auto;">
                        <table class="table table-hover mb-0">
                            <thead style="position:sticky;top:0;background:#f8f9fa;z-index:1;">
                                <tr><th>Tarih</th><th>Kullanıcı</th><th>İşlem</th><th>Entity</th><th>Açıklama</th><th>IP</th></tr>
                            </thead>
                            <tbody>
                                @foreach (var log in auditLogs)
                                {
                                    <tr>
                                        <td style="white-space:nowrap;">@log.OccurredAtUtc.ToString("dd.MM.yyyy HH:mm")</td>
                                        <td>@log.UserId</td>
                                        <td><span class="badge bg-secondary">@log.ActionType</span></td>
                                        <td>@log.EntityName</td>
                                        <td style="font-size:.8rem;">@log.Description</td>
                                        <td><code style="font-size:.75rem;">@log.IpAddress</code></td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="empty-state"><i class="bi bi-shield-check"></i><p>Denetim logu yok</p></div>
                }
            </div>
        </div>
    </div>
</div>
