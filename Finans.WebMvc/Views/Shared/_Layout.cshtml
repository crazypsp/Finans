@using Finans.WebMvc.Security
@inject IMenuPermissionService MenuPermission

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Finans Yönetim Sistemi</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" rel="stylesheet" />
    <link href="~/css/finans-theme.css" rel="stylesheet" />
    @RenderSection("Styles", required: false)
</head>
<body>

    <!-- TOPBAR -->
    <div class="topbar">
        <a class="topbar-brand" href="/Dashboard">
            <i class="bi bi-cash-stack"></i>
            <span>Finans</span>
        </a>

        <button id="sidebarToggle" class="btn btn-sm d-lg-none" style="margin-left:16px;">
            <i class="bi bi-list" style="font-size:1.4rem;"></i>
        </button>

        <div class="topbar-right">
            @if (User.Identity?.IsAuthenticated == true)
            {
                <span class="notification-badge" title="Bildirimler">
                    <i class="bi bi-bell"></i>
                </span>
                <div class="dropdown">
                    <a class="topbar-user dropdown-toggle" href="#" data-bs-toggle="dropdown" aria-expanded="false">
                        <span class="avatar">@(User.Identity.Name?.Substring(0, 1).ToUpper())</span>
                        <span>@User.Identity.Name</span>
                    </a>
                    <ul class="dropdown-menu dropdown-menu-end">
                        <li><a class="dropdown-item" href="/Dashboard"><i class="bi bi-speedometer2 me-2"></i>Dashboard</a></li>
                        <li><hr class="dropdown-divider" /></li>
                        <li>
                            <form method="post" action="/Auth/Logout" style="margin:0;">
                                <button type="submit" class="dropdown-item text-danger"><i class="bi bi-box-arrow-right me-2"></i>Çıkış Yap</button>
                            </form>
                        </li>
                    </ul>
                </div>
            }
        </div>
    </div>

    <!-- SIDEBAR -->
    <nav class="sidebar">
        <ul class="sidebar-nav">
            <li>
                <a href="/Dashboard"><i class="bi bi-speedometer2"></i> Dashboard</a>
            </li>
        </ul>

        @if (MenuPermission.CanSeeTransferMenu(User))
        {
            <div class="sidebar-section">Banka İşlemleri</div>
            <ul class="sidebar-nav">
                <li><a href="/Transfer"><i class="bi bi-arrow-left-right"></i> Hesap Hareketleri</a></li>
                <li><a href="/BankManagement/Banks"><i class="bi bi-building"></i> Banka Tanımları</a></li>
            </ul>

            <div class="sidebar-section">ERP Aktarım</div>
            <ul class="sidebar-nav">
                <li><a href="/ErpTransfer"><i class="bi bi-list-check"></i> Aktarım Kuyrukları</a></li>
                <li><a href="/ErpTransferFailed"><i class="bi bi-exclamation-circle"></i> Başarısız Aktarımlar</a></li>
            </ul>
        }

        @if (MenuPermission.CanSeeRuleAndMappingMenus(User))
        {
            <div class="sidebar-section">Tanımlar</div>
            <ul class="sidebar-nav">
                <li><a href="/ErpCodeMapping"><i class="bi bi-tags"></i> ERP Kod Eşleme</a></li>
                <li><a href="/BankTransactionRule"><i class="bi bi-funnel"></i> Kural Motoru</a></li>
                <li>
                    <a href="#" onclick="if(confirm('ERP hesap planı senkronize edilsin mi?')){document.getElementById('erpSyncForm').submit();} return false;">
                        <i class="bi bi-arrow-repeat"></i> ERP Senkronize
                    </a>
                    <form id="erpSyncForm" method="post" action="/ErpSync/SyncAll" style="display:none;"></form>
                </li>
            </ul>
        }

        @if (MenuPermission.CanSeeReportsMenu(User))
        {
            <div class="sidebar-section">Raporlar & Loglar</div>
            <ul class="sidebar-nav">
                <li><a href="/Report"><i class="bi bi-bar-chart"></i> Raporlar</a></li>
                <li><a href="/SystemLog"><i class="bi bi-journal-text"></i> Sistem Logları</a></li>
            </ul>
        }

        @if (MenuPermission.CanSeeConnectorMenu(User))
        {
            <div class="sidebar-section">Sistem</div>
            <ul class="sidebar-nav">
                <li><a href="/Connector"><i class="bi bi-plug"></i> Desktop Connector</a></li>
            </ul>
        }

        @if (MenuPermission.CanSeeUserManagementMenu(User))
        {
            <div class="sidebar-section">Yönetim</div>
            <ul class="sidebar-nav">
                <li><a href="/Admin/Users"><i class="bi bi-people"></i> Kullanıcı Yönetimi</a></li>
            </ul>
        }
    </nav>

    <!-- MAIN CONTENT -->
    <main class="main-content">
        @if (TempData["Msg"] != null)
        {
            <div class="alert alert-success alert-auto-hide"><i class="bi bi-check-circle"></i> @TempData["Msg"]</div>
        }
        @if (TempData["Err"] != null)
        {
            <div class="alert alert-danger alert-auto-hide"><i class="bi bi-exclamation-triangle"></i> @TempData["Err"]</div>
        }
        @RenderBody()
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/finans.js"></script>
    @RenderSection("Scripts", required: false)
</body>
</html>