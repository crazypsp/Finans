@model IReadOnlyList<Finans.Entities.Banking.BankCredential>

<div class="page-header">
    <h2><i class="bi bi-key me-2"></i>Banka Credential</h2>
    <a href="/BankManagement/Banks" class="btn btn-outline-primary btn-sm"><i class="bi bi-arrow-left me-1"></i>Bankalar</a>
</div>

<div class="card mb-4">
    <div class="card-header"><h6><i class="bi bi-plus-lg me-2"></i>Yeni Credential</h6></div>
    <div class="card-body">
        <form method="post" action="/BankManagement/CreateCredential">
            <div class="row g-2 align-items-end">
                <div class="col-md-2">
                    <label class="form-label">Banka ID</label>
                    <input name="BankId" type="number" class="form-control form-control-sm" required />
                </div>
                <div class="col-md-2">
                    <label class="form-label">Kullanıcı Adı</label>
                    <input name="Username" class="form-control form-control-sm" required />
                </div>
                <div class="col-md-2">
                    <label class="form-label">Şifre</label>
                    <input name="Password" type="password" class="form-control form-control-sm" required />
                </div>
                <div class="col-md-3">
                    <label class="form-label">Ek Parametreler (JSON)</label>
                    <input name="ExtrasJson" class="form-control form-control-sm" placeholder='{"Link":"..."}' />
                </div>
                <div class="col-md-1">
                    <button type="submit" class="btn btn-primary btn-sm"><i class="bi bi-plus me-1"></i>Ekle</button>
                </div>
            </div>
        </form>
    </div>
</div>

@if (Model != null && Model.Count > 0)
{
    <div class="table-container">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead><tr><th>ID</th><th>Banka ID</th><th>Kullanıcı</th><th>Teknoloji</th><th>Auth Yöntem</th><th>Aktif</th></tr></thead>
                <tbody>
                    @foreach (var c in Model)
                    {
                        <tr>
                            <td>@c.Id</td><td>@c.BankId</td><td>@c.Username</td>
                            <td>@c.Technology</td><td>@c.AuthenticationMethod</td>
                            <td><span class="badge @(c.IsActive ? "bg-success" : "bg-danger")">@(c.IsActive ? "Aktif" : "Pasif")</span></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}
