@model IReadOnlyList<Finans.Contracts.ERP.BankTransactionRuleDto>

<div class="page-header">
    <h2><i class="bi bi-funnel me-2"></i>Kural Motoru</h2>
    <a href="/BankTransactionRule/Create" class="btn btn-primary btn-sm"><i class="bi bi-plus-lg me-1"></i>Yeni Kural</a>
</div>

@if (Model != null && Model.Count > 0)
{
    <div class="table-container">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead>
                    <tr><th>ID</th><th>Banka</th><th>Hesap</th><th>Döviz</th><th>B/A</th><th>Açıklama İçerir</th><th>Min</th><th>Max</th><th>Cari</th><th>GL</th><th>Öncelik</th><th>Aktif</th><th>İşlem</th></tr>
                </thead>
                <tbody>
                    @foreach (var x in Model)
                    {
                        <tr>
                            <td>@x.Id</td>
                            <td>@x.BankId</td>
                            <td><code>@x.AccountNumber</code></td>
                            <td>@x.Currency</td>
                            <td>@x.DebitCredit</td>
                            <td>@x.DescriptionContains</td>
                            <td>@x.MinAmount?.ToString("N2")</td>
                            <td>@x.MaxAmount?.ToString("N2")</td>
                            <td><code>@x.CurrentCode</code></td>
                            <td><code>@x.GlCode</code></td>
                            <td>@x.Priority</td>
                            <td><span class="badge @(x.IsActive ? "bg-success" : "bg-danger")">@(x.IsActive ? "Aktif" : "Pasif")</span></td>
                            <td>
                                <form method="post" action="/BankTransactionRule/Delete" style="display:inline;">
                                    <input type="hidden" name="id" value="@x.Id" />
                                    <button type="submit" class="btn btn-danger btn-sm btn-icon" onclick="return confirm('Silmek istediğinize emin misiniz?')">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}
else
{
    <div class="empty-state"><i class="bi bi-funnel"></i><p>Kural tanımı yok.</p></div>
}
