@model IReadOnlyList<Finans.Contracts.Transfer.FailedTransferItemDto>

<div class="page-header">
    <h2><i class="bi bi-exclamation-circle me-2"></i>Başarısız Aktarımlar</h2>
    <span class="breadcrumb-nav"><a href="/Dashboard">Dashboard</a> / Başarısız Aktarımlar</span>
</div>

@if (Model != null && Model.Count > 0)
{
    <form method="post" action="/ErpTransferFailed/RetrySelected">
        <div class="d-flex justify-content-between mb-3">
            <span class="text-muted">@Model.Count başarısız kayıt</span>
            <button type="submit" class="btn btn-warning btn-sm" onclick="return confirm('Seçilen kayıtlar tekrar denensin mi?')">
                <i class="bi bi-arrow-clockwise me-1"></i>Seçilenleri Tekrar Dene
            </button>
        </div>
        <div class="table-container">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead>
                        <tr>
                            <th><input type="checkbox" id="checkAll" class="form-check-input" /></th>
                            <th>ID</th>
                            <th>Batch No</th>
                            <th>İşlem ID</th>
                            <th>Hata</th>
                            <th>GL</th>
                            <th>Cari</th>
                            <th>Tarih</th>
                            <th>İşlem</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var x in Model)
                        {
                            <tr>
                                <td><input type="checkbox" name="selectedIds" value="@x.Id" class="form-check-input rowCheck" /></td>
                                <td>@x.Id</td>
                                <td><code>@x.BatchNo</code></td>
                                <td>@x.BankTransactionId</td>
                                <td><span class="text-danger" style="font-size:.8rem;">@x.ResultMessage</span></td>
                                <td><code>@x.GlCode</code></td>
                                <td><code>@x.CurrentCode</code></td>
                                <td>@x.CreatedAtUtc.ToString("dd.MM.yyyy HH:mm")</td>
                                <td>
                                    <form method="post" action="/ErpTransferFailed/RetryItem" style="display:inline;">
                                        <input type="hidden" name="id" value="@x.Id" />
                                        <button type="submit" class="btn btn-warning btn-sm btn-icon" title="Tekrar Dene">
                                            <i class="bi bi-arrow-clockwise"></i>
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </form>
}
else
{
    <div class="empty-state">
        <i class="bi bi-check-circle"></i>
        <p>Başarısız aktarım kaydı yok.</p>
    </div>
}

@section Scripts {
<script>initCheckAll('checkAll', 'rowCheck');</script>
}
